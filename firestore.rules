rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // Helper functions
    // ============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
        );
    }

    function isLeadOwnerByEmail() {
      return isAuthenticated() &&
        resource != null &&
        resource.data.email == request.auth.token.email;
    }

    // Fluxo público do teste gratuito:
    // permite apenas transição de status "lead" -> "quiz_completed"
    // mantendo campos-base do lead imutáveis.
    function isPublicQuizCompletionUpdate() {
      return resource != null &&
        resource.data.source == 'teste-gratuito' &&
        resource.data.status == 'lead' &&
        request.resource.data.status == 'quiz_completed' &&
        request.resource.data.source == resource.data.source &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.fullName == resource.data.fullName &&
        request.resource.data.whatsapp == resource.data.whatsapp &&
        request.resource.data.age == resource.data.age &&
        request.resource.data.timeframe == resource.data.timeframe &&
        request.resource.data.createdAt == resource.data.createdAt;
    }

    // ============================================================
    // Users collection
    // ID do documento = UID do usuário
    // ============================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if false;

      // Subcoleção de histórico de créditos
      // Leitura: o próprio usuário ou admin
      // Escrita: o próprio usuário (via runTransaction no credits.ts) ou admin
      match /creditHistory/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if false; // transacões são imutáveis
      }
    }

    // ============================================================
    // Questionnaires collection
    // ID do documento = UID do usuário
    // ============================================================
    match /questionnaires/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ============================================================
    // Analysis results collection
    // Suporta tanto setDoc(userId) quanto addDoc(ID automático)
    // ============================================================
    match /analysisResults/{docId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == docId ||
        (resource != null && resource.data.userId == request.auth.uid)
      ) || isAdmin();
      // Cliente pode criar (necessário para addDoc e setDoc do web)
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      // Somente Cloud Functions podem atualizar/deletar  
      allow update, delete: if false;
    }

    // ============================================================
    // Visa paths collection
    // ID do documento = UID do usuário
    // ============================================================
    match /visaPaths/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ============================================================
    // Training sessions collection (uso do Web - treinamento com IA)
    // Coleção: training_sessions (com underscore)
    // ============================================================
    match /training_sessions/{sessionId} {
      // Query por userId: permite se o usuário é o dono
      allow read: if isAuthenticated() && (
        resource == null ||
        resource.data.userId == request.auth.uid
      ) || isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // Training stats collection (uso do Web)
    // ID do documento = UID do usuário
    // ============================================================
    match /training_stats/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ============================================================
    // Subscriptions collection (Stripe - uso do Web)
    // ============================================================
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid || isAdmin();
      // Somente Cloud Functions/webhook do Stripe escrevem
      allow write: if false;
    }

    // ============================================================
    // Payment intents collection (Stripe - uso do Web)
    // ============================================================
    match /paymentIntents/{paymentId} {
      allow read: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid || isAdmin();
      // Somente Cloud Functions escrevem
      allow write: if false;
    }

    // ============================================================
    // Detailed reports collection
    // ============================================================
    match /detailedReports/{reportId} {
      allow read: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid || isAdmin();
      allow write: if false;
    }

    // ============================================================
    // DS-160 helper data (uso do Web)
    // ============================================================
    match /ds160/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);
    }

    // ============================================================
    // Chat sessions (uso do Web - chat com IA)
    // ============================================================
    match /chatSessions/{sessionId} {
      allow read: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid || isAdmin();
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() &&
        resource != null &&
        resource.data.userId == request.auth.uid;
    }

    // ============================================================
    // Leads collection (captura de leads do teste-gratuito.tsx)
    // Qualquer pessoa pode criar (não requer login)
    // Atualização pública permitida apenas para concluir quiz do próprio lead
    // ============================================================
    match /leads/{leadId} {
      allow create: if true; // público — para capturar leads sem conta
      allow read: if isLeadOwnerByEmail() || isAdmin();
      allow update: if isLeadOwnerByEmail() || isAdmin() || isPublicQuizCompletionUpdate();
      allow delete: if false;
    }

  }
}
